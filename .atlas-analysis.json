  "keyFeatures": [
    "Event-driven architecture for Discord bot development",
    "RestAction-based async API with callbacks and futures",
    "Gateway intents and customizable member caching",
    "Full support for slash commands and interactions",
    "Audio connections with DAVE protocol support",
    "Sharding support for scaling to large bot deployments",
    "Comprehensive entity models for Discord resources",
    "Rate limit handling and REST API management"
  ],
  "publicApiSurface": [
    "JDA - Main API interface",
    "JDABuilder - Builder for creating JDA instances",
    "DefaultShardManagerBuilder - Builder for sharded bots",
    "RestAction<T> - Async request builder",
    "ListenerAdapter - Event listener base class",
    "GatewayIntent - Gateway event subscriptions",
    "Guild - Server entity",
    "Member - Guild member entity",
    "User - User entity",
    "Message - Message entity",
    "MessageChannel - Text channel interface",
    "EmbedBuilder - Rich embed builder",
    "SlashCommandInteractionEvent - Slash command event",
    "InteractionHook - Interaction response handler",
    "AudioManager - Voice connection manager",
    "Permission - Permission flags",
    "CacheFlag - Cache configuration flags",
    "MemberCachePolicy - Member caching strategies"
  ]
